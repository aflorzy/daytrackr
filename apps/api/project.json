{
  "name": "api",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "sourceRoot": "apps/api/src",
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "command": "mvn clean package -DskipTests",
        "cwd": "apps/api"
      },
      "configurations": {
        "production": {
          "command": "mvn clean package -DskipTests -Dspring.profiles.active=prd",
          "cwd": "apps/api"
        },
        "development": {
          "command": "mvn clean package -DskipTests -Dspring.profiles.active=dev",
          "cwd": "apps/api"
        }
      }
    },
    "serve": {
      "executor": "nx:run-commands",
      "options": {
        "command": "mvn spring-boot:run -Dspring-boot.run.profiles=dev",
        "cwd": "apps/api"
      },
      "configurations": {
        "production": {
          "command": "mvn spring-boot:run -Dspring-boot.run.profiles=prd",
          "cwd": "apps/api"
        },
        "development": {
          "command": "mvn spring-boot:run -Dspring-boot.run.profiles=dev",
          "cwd": "apps/api"
        }
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "command": "mvn test",
        "cwd": "apps/api"
      },
      "configurations": {
        "production": {
          "command": "mvn test -Dspring.profiles.active=prd",
          "cwd": "apps/api"
        },
        "ci": {
          "command": "mvn test -Dspring.profiles.active=ci",
          "cwd": "apps/api"
        }
      }
    },
    "clean": {
      "executor": "nx:run-commands",
      "options": {
        "command": "mvn clean",
        "cwd": "apps/api"
      }
    },
    "install": {
      "executor": "nx:run-commands",
      "options": {
        "command": "mvn install",
        "cwd": "apps/api"
      }
    }
  },
  "tags": []
}
