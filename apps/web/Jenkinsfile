pipeline {
    agent any
    options {
        // This is required if you want to clean before build
        skipDefaultCheckout(true)
    }
    environment {
        VERSION_IMAGE_LABEL = "${MAJOR_MINOR}.${BUILD_NUMBER}-${ENV}"
        REGISTRY="gitea.local.aflorzy.com"
        IMAGE_NAME="daytrackr-frontend"
    }

    stages {
        stage ('Checkout SCM') {
            steps {
                git branch: 'main', credentialsId: 'gitea', url: 'git@192.168.1.205:aflorzy/daytrackr-parser.git'
            }
        }
        stage ('Setup') {
            steps {
                sh 'docker build -f runner.dockerfile -t runner:latest'
            }
        }
        stage ('Install Dependencies') {
            environment {
                workspace = pwd()
            }
            steps {
                sh 'docker run --rm -v ${workspace}:/workspace runner:latest npm install --prefix /workspace'
            }
        }
        stage ('Run Tests') {
            environment {
                workspace = pwd()
            }
            steps {
                sh 'docker run --rm -v ${workspace}:/workspace runner:latest npm run test:ci --prefix /workspace'
            }
        }
        stage ('Build Docker Image') {
            steps {
                sh 'docker build -t ${IMAGE_NAME} .'
            }
        }
    }
    post {
        always {
            echo 'Logout Docker'
            sh 'docker logout ${REGISTRY}'
        }
    }
}
