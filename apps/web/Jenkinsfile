node {
  // Define the agent block with the Docker image
  docker.image('gradle:8.2.0-jdk17-alpine').inside {
    try {
      // Your pipeline steps
      stage('Build') {
        sh 'docker build -t aflorzy/daytrackr-frontend .'
      }
      stage('Login') {
        sh 'echo $DOCKERHUB_CREDENTIALS_PSW | docker login -u $DOCKERHUB_CREDENTIALS_USR --password-stdin'
      }
      stage('Push') {
        sh 'docker push aflorzy/daytrackr-frontend'
      }
    } finally {
      // Ensure Docker logout
      sh 'docker logout'
    }
  }
}
